# ============================================================
# SuperNovba 环境变量模板
# ============================================================
# 复制此文件为 apps/web/.env.local 并填入真实密钥
# ============================================================

# ============================================================
# DeepSeek API — 文本生成
# 获取地址：https://platform.deepseek.com/api_keys
# ============================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================
# 火山引擎 Seedream 5.0 (Ark 平台) — 图片生成
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# ============================================================
VOLCENGINE_API_KEY=your-ark-api-key
VOLCENGINE_MODEL=doubao-seedream-5.0-260128
VOLCENGINE_REGION=cn-north-1
VOLCENGINE_API_HOST=https://ark.cn-beijing.volces.com

# ============================================================
# Supabase — 数据库 / 认证 / 存储
# 获取地址：https://app.supabase.com → 项目 → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# App 配置
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SuperNovba
